{
  "name": "BookBrief AI Workflow",
  "nodes": [
    {
      "name": "Google Drive Trigger",
      "type": "googleDriveTrigger",
      "parameters": {
        "folderToWatch": "YOUR_INPUT_FOLDER_ID"
      }
    },
    {
      "name": "Download File",
      "type": "googleDrive"
    },
    {
      "name": "Check File Type",
      "type": "if"
    },
    {
      "name": "Extract PDF",
      "type": "extractFromFile"
    },
    {
      "name": "Extract Text",
      "type": "extractFromFile"
    },
    {
      "name": "Merge",
      "type": "merge"
    },
    {
      "name": "Prepare Text",
      "type": "code"
    },
    {
      "name": "LLM Chain",
      "type": "llm"
    },
    {
      "name": "Groq Model",
      "type": "llmModel"
    },
    {
      "name": "Format Output",
      "type": "code"
    },
    {
      "name": "Upload Summary",
      "type": "googleDrive",
      "parameters": {
        "folderId": "YOUR_OUTPUT_FOLDER_ID"
      }
    }
  ]
}
